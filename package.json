{
  "name": "tic-analyzer",
  "version": "1.0.0",
  "description": "TIC Analyzer — Motor local de análise para projetos grandes",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "npx concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && npm run copy:grammars && electron dist/electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && npm run copy:grammars",
    "copy:grammars": "node scripts/copy-grammars.mjs",
    "rebuild:electron": "electron-builder install-app-deps",
    "verify": "npm run build:electron && node scripts/verify-semantic.mjs && node scripts/verify-store.mjs && node scripts/verify-crosstier.mjs && node scripts/verify-orm.mjs && node scripts/verify-impact.mjs && node scripts/verify-health.mjs && node scripts/verify-pr-review.mjs && node scripts/verify-embeddings.mjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:portable": "npm run build && electron-builder --win zip",
    "dist:win:dir": "npm run build && electron-builder --win dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "cli": "node dist/src/cli/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "express": "^4.18.2",
    "mermaid": "^11.15.0",
    "node-sql-parser": "^5.4.0",
    "vis-network": "^10.1.0",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.3.2",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.tic.analyzer",
    "productName": "TIC Analyzer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "sign": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "bin": {
    "tic-analyzer": "dist/src/cli/index.js"
  }
}
